# Copy this file to .env and fill the real secrets before running the servers
# Frontend: base URL used when running locally
VITE_API_BASE_URL=http://localhost:3001

# Server
PORT=3001
NODE_ENV=development

# Supabase (required for server to connect)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini / Google GenAI
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Optional: adjust these if you need different ports for dev
CLIENT_PORT=5173
AI_LEARNING_PORT=3000
