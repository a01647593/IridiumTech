---
import { getSession, redirectByRole } from '../lib/auth.js';
import '../styles/global.css';

const session = getSession(Astro.cookies);
if (session) return Astro.redirect(redirectByRole(session.rol));
---

<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>AI Learning Hub | Iniciar Sesión</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .bg-login-gradient {
      background: linear-gradient(135deg, #00344c 0%, #1B4B66 100%);
    }
    .abstract-pattern {
      background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
      background-size: 32px 32px;
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25%       { transform: translateX(-6px); }
      75%       { transform: translateX(6px); }
    }
    .shake { animation: shake 0.35s ease; }
  </style>
</head>

<body class="bg-surface text-on-surface antialiased min-h-screen flex">
<main class="flex w-full min-h-screen">

  <!-- Lado izquierdo: Brand -->
  <section class="hidden lg:flex lg:w-1/2 bg-login-gradient relative overflow-hidden flex-col justify-between p-16">
    <div class="absolute inset-0 abstract-pattern opacity-40"></div>
    <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full blur-[120px]" style="background-color: rgba(0, 163, 224, 0.15);"></div>

    <div class="relative z-10">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/10 backdrop-blur-md rounded-xl flex items-center justify-center border border-white/10">
          <span class="material-symbols-outlined text-white">neurology</span>
        </div>
        <span class="text-2xl font-extrabold tracking-tighter text-white">AI Learning Hub</span>
      </div>
    </div>

    <div class="relative z-10 max-w-lg">
      <h1 class="text-5xl font-extrabold text-white tracking-tight leading-tight mb-6">
        Potenciando el futuro del aprendizaje corporativo.
      </h1>
      <p class="text-on-primary-container text-lg font-medium leading-relaxed">
        Capacitación inteligente para equipos modernos mediante inteligencia artificial generativa y rutas de aprendizaje adaptativas.
      </p>
    </div>

    <div class="relative z-10">
      <div class="flex items-center gap-6">
        <div class="flex -space-x-3">
          <img class="w-10 h-10 rounded-full border-2 border-primary-container object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCr2k-k-zfXETrbiPAsmmd5gtKf3TUbetmc3JeU7Tnotg81Y3Lh7mfEsiODuNByBnbVZgXf9sZYVTVSGNa3nV7J3Ro2jIBgSL9snuM7K7kpClijEEk4LTdQgEb1WJQZcpiQwTVT50jGgeNLf4s7Jj-rpyFVUGbNlcE6ficyiDFC4bVuorc_3L1PawQ_9cGK8fQRr6wuvrtUbiUpSsuKnLQ_C2Qtdu6tZlkNV9aQss-aZLiYYfeifzWHU6T8dXyfWxsHe-j03Lxl9p8x" alt=""/>
          <img class="w-10 h-10 rounded-full border-2 border-primary-container object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC9lnhVqnHfisbRpp8iZgdhfaYU5fRKUKPUa0MicBtDIoISRTKhlJW-Z12BefBuqUrdX8da02uevL9X6qoXZW6wjcAdg0tgAZJq7tkkSr5O3DyS8crInivmVd-1rMWtVEo6GIpCEa3qxRqp1XRXgSlJJUaW68wEU8yR6XdaVn3vX_SWHojbvhkHcGHkjRk7JAFeRFMObvu6Tzx5twyY5fP9NkaL1y7LF6XzOXqvzOMQKTQPXXTYuXcOv60yfhoHHJxMQt1PA4hItnPD" alt=""/>
          <img class="w-10 h-10 rounded-full border-2 border-primary-container object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBzA0J0GmJGoB7pR1MgLCrAYnpJqbvl3MgGAo1kQ-WBXLcgLz_PwyervCoxCmIfU0G4jTFDX_kPu9Cgf4pv_w7Xfhy3pp79g8U-gOMW5fNLdD3RTdfbW6UIn1G5MdvhbMU_2RJM2f1MzcfqZ816JbtRGcqMTwPnTMk38MMHf8H91q2kV8iLP--QcHkA4IKk8EWBG4wPd6xicL3Ua1PGIiUnjpsMmvHgETFjAgAxLOzjPy67I9U8tL-IjJe_ruXn9fNxOfn-it2EaGbw" alt=""/>
        </div>
        <p class="text-white/60 text-sm font-medium">Más de 500 empresas ya están transformando sus equipos.</p>
      </div>
    </div>
  </section>

  <!-- Lado derecho: Formulario -->
  <section class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 bg-surface">
    <div class="w-full max-w-md">

      <!-- Logo mobile -->
      <div class="lg:hidden flex justify-center mb-12">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary-container text-3xl">neurology</span>
          <span class="text-xl font-extrabold tracking-tighter text-primary-container">AI Learning Hub</span>
        </div>
      </div>

      <!-- Header -->
      <header class="mb-10">
        <h2 class="text-3xl font-bold text-on-surface tracking-tight mb-2">Iniciar Sesión</h2>
        <p class="text-on-surface-variant font-medium">Accede con tu cuenta corporativa para continuar.</p>
      </header>

      <!-- Alerta de error (oculta por defecto) -->
      <div id="error-alert" class="hidden mb-6 flex items-start gap-3 px-4 py-3 rounded-xl bg-error-container text-on-error-container text-sm font-medium">
        <span class="material-symbols-outlined text-base mt-0.5 flex-shrink-0">error</span>
        <span id="error-msg"></span>
      </div>

      <!-- Formulario -->
      <form id="login-form" class="space-y-6" novalidate>

        <!-- Correo -->
        <div class="space-y-2">
          <label class="text-sm font-semibold text-on-surface-variant ml-1" for="correo">
            Correo Electrónico
          </label>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-outline text-xl group-focus-within:text-[#00A3E0] transition-colors">mail</span>
            </div>
            <input
              id="correo"
              type="email"
              placeholder="nombre@empresa.com"
              class="block w-full pl-11 pr-4 py-3.5 bg-surface-container-highest border-none rounded-xl text-on-surface placeholder:text-outline focus:ring-2 focus:ring-[#00A3E0] transition-all font-medium"
            />
          </div>
        </div>

        <!-- Contraseña -->
        <div class="space-y-2">
          <div class="flex justify-between items-center px-1">
            <label class="text-sm font-semibold text-on-surface-variant" for="password">Contraseña</label>
            <a class="text-sm font-bold text-secondary hover:text-primary transition-colors" href="#">¿Olvidaste tu contraseña?</a>
          </div>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <span class="material-symbols-outlined text-outline text-xl group-focus-within:text-[#00A3E0] transition-colors">lock</span>
            </div>
            <input
              id="password"
              type="password"
              placeholder="••••••••"
              class="block w-full pl-11 pr-12 py-3.5 bg-surface-container-highest border-none rounded-xl text-on-surface placeholder:text-outline focus:ring-2 focus:ring-[#00A3E0] transition-all font-medium"
            />
            <button
              id="toggle-password"
              type="button"
              class="absolute inset-y-0 right-0 pr-4 flex items-center text-outline hover:text-on-surface transition-colors"
            >
              <span id="eye-icon" class="material-symbols-outlined text-xl">visibility</span>
            </button>
          </div>
        </div>

        <!-- Recordarme -->
        <div class="flex items-center space-x-2 px-1">
          <input
            id="remember"
            type="checkbox"
            class="w-5 h-5 rounded border-outline-variant cursor-pointer"
            style="accent-color: #00344c;"
          />
          <label class="text-sm font-medium text-on-surface-variant cursor-pointer select-none" for="remember">
            Recordarme en este dispositivo
          </label>
        </div>

        <!-- Botones -->
        <div class="space-y-4 pt-2">
          <button
            id="submit-btn"
            type="submit"
            class="w-full bg-primary-container text-white font-bold py-4 rounded-xl shadow-lg hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="btn-label">Ingresar</span>
            <span id="btn-arrow" class="material-symbols-outlined text-lg">arrow_forward</span>
            <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
            </svg>
          </button>

          <div class="relative flex items-center py-2">
            <div class="flex-grow border-t border-outline-variant/30"></div>
            <span class="flex-shrink mx-4 text-xs font-bold text-outline uppercase tracking-widest">O</span>
            <div class="flex-grow border-t border-outline-variant/30"></div>
          </div>

          <button
            type="button"
            class="w-full bg-surface-container-lowest border border-outline-variant/30 text-on-surface font-bold py-4 rounded-xl hover:bg-surface-container-low transition-colors flex items-center justify-center gap-3"
            onclick="alert('SSO no configurado en este entorno.')"
          >
            <span class="material-symbols-outlined text-xl">passkey</span>
            Iniciar sesión con SSO
          </button>
        </div>

      </form>

      <!-- Footer de seguridad -->
      <footer class="mt-12 flex flex-col items-center gap-4">
        <div class="flex items-center gap-2 px-4 py-2 rounded-full" style="background-color: #E6F6FC;">
          <span class="material-symbols-outlined text-base" style="color:#00658d; font-variation-settings: 'FILL' 1;">verified_user</span>
          <span class="text-xs font-bold text-on-secondary-container tracking-wide">Acceso seguro con cifrado TLS 1.3</span>
        </div>
        <div class="flex gap-6">
          <a class="text-xs font-semibold text-outline hover:text-on-surface underline decoration-outline-variant/50 transition-colors" href="#">Términos de Servicio</a>
          <a class="text-xs font-semibold text-outline hover:text-on-surface underline decoration-outline-variant/50 transition-colors" href="#">Privacidad</a>
          <a class="text-xs font-semibold text-outline hover:text-on-surface underline decoration-outline-variant/50 transition-colors" href="#">Soporte IT</a>
        </div>
      </footer>

    </div>
  </section>
</main>

<script>
  // Toggle mostrar/ocultar contraseña
  document.getElementById('toggle-password').addEventListener('click', () => {
    const input = document.getElementById('password');
    const icon  = document.getElementById('eye-icon');
    input.type  = input.type === 'password' ? 'text' : 'password';
    icon.textContent = input.type === 'password' ? 'visibility' : 'visibility_off';
  });

  // Envío del formulario
  document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const correo   = document.getElementById('correo').value.trim();
    const password = document.getElementById('password').value;
    const alert    = document.getElementById('error-alert');
    const msg      = document.getElementById('error-msg');
    const btn      = document.getElementById('submit-btn');
    const label    = document.getElementById('btn-label');
    const arrow    = document.getElementById('btn-arrow');
    const spinner  = document.getElementById('btn-spinner');

    // Ocultar error anterior
    alert.classList.add('hidden');

    // Validación básica en cliente
    if (!correo || !password) {
      msg.textContent = 'Completa todos los campos.';
      alert.classList.remove('hidden');
      return;
    }

    // Estado de carga
    btn.disabled        = true;
    label.textContent   = 'Verificando...';
    arrow.classList.add('hidden');
    spinner.classList.remove('hidden');

    try {
      const res  = await fetch('/api/auth/login', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ correo, password }),
      });

      const data = await res.json();

      if (!data.ok) {
        msg.textContent = data.error || 'Credenciales incorrectas.';
        alert.classList.remove('hidden');
        alert.classList.add('shake');
        setTimeout(() => alert.classList.remove('shake'), 400);
        return;
      }

      // Redirigir al panel según el rol
      window.location.href = data.redirectTo;

    } catch {
      msg.textContent = 'No se pudo conectar con el servidor.';
      alert.classList.remove('hidden');
    } finally {
      btn.disabled      = false;
      label.textContent = 'Ingresar';
      arrow.classList.remove('hidden');
      spinner.classList.add('hidden');
    }
  });
</script>

</body>
</html>